{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/privacy-policy",
      "destination": "/legal/privacy-policy",
      "permanent": true
    },
    {
      "source": "/privacy",
      "destination": "/legal/privacy-policy",
      "permanent": true
    },
    {
      "source": "/terms-of-service",
      "destination": "/legal/terms-of-service",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/legal",
      "destination": "/legal/index.html"
    },
    {
      "source": "/legal/privacy-policy",
      "destination": "/legal/privacy-policy.html"
    },
    {
      "source": "/legal/terms-of-service",
      "destination": "/legal/terms-of-service.html"
    },
    {
      "source": "/legal/cookie-policy",
      "destination": "/legal/cookie-policy.html"
    },
    {
      "source": "/legal/data-processing",
      "destination": "/legal/data-processing.html"
    }
  ]
}
